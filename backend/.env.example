# Dev account (for seed)
DEV_EMAIL=admin@example.com
DEV_PASSWORD=
DEV_NAME=Admin

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/datapim
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=datapim

# App
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:5174

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRES_MINUTES=1440
JWT_REFRESH_EXPIRES_DAYS=7

# Storage
UPLOAD_DIR=./uploads
INBOX_DIR=./inbox

# AI (optional, for v1.2)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
