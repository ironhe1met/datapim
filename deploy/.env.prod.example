# =============================================================================
# DataPIM — production environment template.
# Copy to project root as `.env.prod` and fill in real values:
#   cp deploy/.env.prod.example .env.prod
#   chmod 600 .env.prod
# Never commit .env.prod.
# =============================================================================

# --- Environment ------------------------------------------------------------
ENVIRONMENT=production
LOG_LEVEL=INFO

# --- Domain / URLs ----------------------------------------------------------
# Public domain — used in CORS, callbacks, and the frontend bundle.
APP_URL=https://datapim.example.com
API_URL=https://datapim.example.com
# Frontend bundle picks this up at build time (baked into JS).
VITE_API_URL=https://datapim.example.com
# Comma-separated list of origins allowed to call the API.
CORS_ORIGINS=https://datapim.example.com

# --- PostgreSQL -------------------------------------------------------------
# Generate: openssl rand -base64 24
POSTGRES_USER=datapim
POSTGRES_PASSWORD=CHANGEME_strong_random_password
POSTGRES_DB=datapim
# Internal hostname `postgres` resolves inside the compose network.
DATABASE_URL=postgresql+asyncpg://datapim:CHANGEME_strong_random_password@postgres:5432/datapim

# --- JWT --------------------------------------------------------------------
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGEME_long_random_secret
JWT_ACCESS_EXPIRES_MINUTES=1440
JWT_REFRESH_EXPIRES_DAYS=7

# --- Storage ----------------------------------------------------------------
# Inside the backend container. Volume `datapim_inbox` is mounted at /app/inbox.
XML_IMPORT_DIR=/app/inbox/xml

# --- Bootstrap admin (used by seed.py on first run) -------------------------
# Leave blank to skip auto-seeding; create the admin manually instead.
DEV_EMAIL=
DEV_PASSWORD=
DEV_NAME=

# --- Uvicorn ----------------------------------------------------------------
# Rule of thumb: (2 * CPU) + 1, capped by RAM (~150-200MB per worker).
UVICORN_WORKERS=2

# --- AI providers (optional) ------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
