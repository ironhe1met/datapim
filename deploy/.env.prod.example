# =============================================================================
# DataPIM — production environment.
# Copy as `.env.prod` in project root, fill the marked fields, then run
#   sudo bash deploy/setup.sh
# `setup.sh` will generate POSTGRES_PASSWORD + JWT_SECRET and persist them
# back into this file. Don't commit .env.prod.
# =============================================================================

# --- REQUIRED: domain + admin contacts ---------------------------------------
# Bare hostname, no scheme. A-record must already point at this VPS.
DOMAIN=datapim.example.com
# Used by Let's Encrypt for renewal notifications.
ADMIN_EMAIL=you@example.com

# --- REQUIRED: bootstrap admin (created on first run) ------------------------
DEV_EMAIL=admin@example.com
DEV_PASSWORD=change-this-strong-password
DEV_NAME=Admin

# --- Auto-derived (setup.sh fills these — leave defaults) --------------------
ENVIRONMENT=production
LOG_LEVEL=INFO
POSTGRES_USER=datapim
POSTGRES_DB=datapim
POSTGRES_PASSWORD=__FILL_BY_SCRIPT__
JWT_SECRET=__FILL_BY_SCRIPT__
DATABASE_URL=__FILL_BY_SCRIPT__
APP_URL=__FILL_BY_SCRIPT__
API_URL=__FILL_BY_SCRIPT__
VITE_API_URL=__FILL_BY_SCRIPT__
CORS_ORIGINS=__FILL_BY_SCRIPT__
JWT_ACCESS_EXPIRES_MINUTES=1440
JWT_REFRESH_EXPIRES_DAYS=7
XML_IMPORT_DIR=/app/inbox/xml
UVICORN_WORKERS=2

# --- Optional: AI providers (leave blank for v1.0) --------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
